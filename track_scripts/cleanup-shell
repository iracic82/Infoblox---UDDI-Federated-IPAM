#!/bin/bash
set -euxo pipefail

echo "🧹 Starting UDDI IPAM cleanup..."

cd /root/infoblox-lab/uddi-ipam/scripts || {
  echo "❌ Failed to cd into script directory. Exiting."
  exit 1
}

# Optional cleanup scripts — uncomment if needed
